{
  "expo": {
    "name": "Badoo",
    "slug": "badoo",
    "owner": "omerexpo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "badoo",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.omerexpo.badoo",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Story paylaşmak için kamera erişimine ihtiyacımız var."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF1E5",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Günlük adım ve yürüyüş mesafenizi takip etmek için Apple Sağlık verilerinize erişmemiz gerekiyor.",
          "NSHealthUpdateUsageDescription": "Manuel aktivite kayıtlarınızı Apple Sağlık ile senkronize etmek için izin gerekiyor."
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF9F3",
          "image": "./assets/icon.png",
          "imageWidth": 160
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Profil fotoğrafı seçmek için galeri erişimine ihtiyacımız var.",
          "cameraPermission": "Story paylaşmak için kamera erişimine ihtiyacımız var."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2a46f6d3-4365-48f3-ab72-f23dae89c3f4"
      }
    }
  }
}